# Порт сервера
PORT=3000

# Leadteh API (общий токен аккаунта)
LEADTEH_API_TOKEN=ваш_токен_leadteh

# ============================================
# Вариант 1: Один бот (обратная совместимость)
# ============================================
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
LEADTEH_BOT_ID=257034

# ============================================
# Вариант 2: Несколько ботов
# (если задан BOT_1_TOKEN, старые переменные игнорируются)
# ============================================
# Бот 1
# BOT_1_NAME=Основной бот
# BOT_1_TOKEN=123456:ABC-DEF...
# BOT_1_LEADTEH_ID=257034

# Бот 2
# BOT_2_NAME=Второй бот
# BOT_2_TOKEN=789012:GHI-JKL...
# BOT_2_LEADTEH_ID=300001

# ============================================
# Общее
# ============================================
# Telegram ID администраторов (через запятую)
ADMIN_TELEGRAM_IDS=123456789,987654321

# Секрет для ручного вызова /api/cron/send (необязательно на VPS)
CRON_SECRET=any_random_string
