# SaaS Platform Configuration
# ============================================

# Порт сервера
PORT=3000

# Токен платформенного бота (для валидации initData)
# Это бот, через который ВСЕ пользователи открывают Mini App
PLATFORM_BOT_TOKEN=123456:ABC-DEF...

# Секрет для ручного вызова /api/cron/send (необязательно на VPS)
CRON_SECRET=any_random_string

# Telegram ID суперадмина платформы
SUPER_ADMIN_ID=YOUR_TELEGRAM_ID_HERE

# Бесплатный режим — отключает все лимиты, подписки и оплату
# Управляется из суперадмин-панели (Цены → переключатель)
# Можно принудительно задать здесь: true/false (перезаписывает БД)
# FREE_MODE=true

# Ключ шифрования токенов (AES-256-GCM, 64 hex символа)
# Если не задан — генерируется автоматически при первом запуске
# ВАЖНО: без этого ключа зашифрованные данные будут потеряны!
ENCRYPTION_KEY=

# ============================================
# Платёжный шлюз (tbank / robokassa / пусто = ручной режим)
# ============================================
PAYMENT_PROVIDER=tbank
BASE_URL=https://broadcast.leadtehsms.ru

# ТБанк Acquiring
TBANK_TERMINAL_KEY=
TBANK_PASSWORD=
TBANK_TEST_MODE=true

# Робокасса (альтернатива)
ROBOKASSA_LOGIN=
ROBOKASSA_PASSWORD1=
ROBOKASSA_PASSWORD2=
ROBOKASSA_TEST_MODE=true

# ============================================
# Все остальные настройки (боты, Leadteh, админы)
# хранятся в SQLite: data/broadcast.db
# ============================================
